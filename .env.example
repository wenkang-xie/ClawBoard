# Agent Dashboard Configuration
# 复制此文件为 .env 并根据需要修改值

# ─────────────────────────────────────────────
# BFF Server Configuration
# ─────────────────────────────────────────────

# BFF 服务端口（默认 18902）
BFF_PORT=18902
# BFF 监听地址（默认仅本地）
BFF_HOST=127.0.0.1
# BFF 完整 URL（前端使用，默认本地开发）
VITE_BFF_BASE=http://127.0.0.1:18902

# ─────────────────────────────────────────────
# OpenClaw/Gateway Configuration
# ─────────────────────────────────────────────

# Gateway WebSocket 地址（默认本地）
VITE_GATEWAY_WS_URL=ws://localhost:18789
# Gateway API Token（可选，用于认证）
# GATEWAY_TOKEN=your_token_here

# ─────────────────────────────────────────────
# File System Paths
# ─────────────────────────────────────────────

# OpenClaw 根目录（默认 ~/.openclaw）
OPENCLAW_HOME=
# 工作空间目录（默认 ${OPENCLAW_HOME}/workspace）
# WORKSPACE_DIR=
# 任务文件路径（默认 ${WORKSPACE_DIR}/tasks/running_tasks.md）
# TASKS_FILE=
# Memory 目录（默认 ${WORKSPACE_DIR}/memory）
# MEMORY_DIR=
