# ClawBoard configuration
# Copy this file to .env and adjust values if needed.

# --------------------------------------------------
# BFF server
# --------------------------------------------------

# BFF port
BFF_PORT=18902
# BFF bind host
BFF_HOST=127.0.0.1
# Frontend-visible BFF base URL
VITE_BFF_BASE=http://127.0.0.1:18902

# --------------------------------------------------
# OpenClaw / Gateway
# --------------------------------------------------

# OpenClaw Gateway WebSocket URL
VITE_GATEWAY_WS_URL=ws://localhost:18789
# Optional gateway API token
# GATEWAY_TOKEN=your_token_here

# --------------------------------------------------
# File system paths
# --------------------------------------------------

# OpenClaw home directory (default: ~/.openclaw)
OPENCLAW_HOME=
# Optional: workspace directory override (default: ${OPENCLAW_HOME}/workspace)
# WORKSPACE_DIR=
# Optional: task file override (default: ${WORKSPACE_DIR}/tasks/running_tasks.md)
# TASKS_FILE=
# Optional: memory directory override (default: ${WORKSPACE_DIR}/memory)
# MEMORY_DIR=
